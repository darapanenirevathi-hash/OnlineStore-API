    {
      "name": "Get Single Cart Item",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const cart = pm.response.json();  //get Response object\r",
              "const expected_schema = {\r",
              "  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\r",
              "  \"title\": \"Cart Response Schema\",\r",
              "  \"type\": \"object\",\r",
              "  \"properties\": {\r",
              "    \"id\": { \"type\": \"integer\" },\r",
              "    \"userId\": { \"type\": \"integer\" },\r",
              "    \"date\": { \"type\": \"string\", \"format\": \"date-time\" },\r",
              "    \"products\": {\r",
              "      \"type\": \"array\",\r",
              "      \"minItems\": 1,\r",
              "      \"items\": {\r",
              "        \"type\": \"object\",\r",
              "        \"properties\": {\r",
              "          \"productId\": { \"type\": \"integer\" },\r",
              "          \"quantity\": { \"type\": \"integer\" }\r",
              "        },\r",
              "        \"required\": [\"productId\", \"quantity\"]\r",
              "      }\r",
              "    },\r",
              "    \"__v\": { \"type\": \"integer\" }\r",
              "  },\r",
              "  \"required\": [\"id\", \"userId\", \"date\", \"products\", \"__v\"]\r",
              "};\r",
              "\r",
              "// 1️⃣ Response is an object and not empty\r",
              "pm.test(\"Response is an object and not empty\", function () {\r",
              "    pm.expect(cart).to.be.an(\"object\");\r",
              "    pm.expect(Object.keys(cart).length).to.be.above(0);\r",
              "});\r",
              "\r",
              "// 2️⃣ Validate cart ID\r",
              "\r",
              "const expectedCartId = pm.environment.get(\"cart_id\"); // string from env/collection\r",
              "\r",
              "pm.test(\"Expected cart ID validation\", function() {\r",
              "    // Convert both to strings to handle both numbers and UUIDs\r",
              "    pm.expect(cart.id.toString()).to.eql(expectedCartId.toString());\r",
              "});\r",
              "\r",
              "console.log(\"Response cart ID:\", cart.id);\r",
              "console.log(\"Expected cart ID variable:\", expectedCartId);\r",
              "\r",
              "// 3️⃣ JSON schema validation\r",
              "pm.test(\"Expected JSON schema validation\", function(){\r",
              "    pm.response.to.have.jsonSchema(expected_schema);\r",
              "});\r",
              "\r",
              "// 4️⃣ Status code validation\r",
              "pm.test(\"successful response validation\", function(){\r",
              "    pm.response.to.have.status(200);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
