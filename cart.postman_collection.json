      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json_response = pm.response.json();\r",
              "const  expected_schema = {\r",
              "  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\r",
              "  \"title\": \"Generated schema for Root\",\r",
              "  \"type\": \"array\",\r",
              "  \"items\": {\r",
              "    \"type\": \"object\",\r",
              "    \"properties\": {\r",
              "      \"id\": {\r",
              "        \"type\": \"number\"\r",
              "      },\r",
              "      \"userId\": {\r",
              "        \"type\": \"number\"\r",
              "      },\r",
              "      \"date\": {\r",
              "        \"type\": \"string\"\r",
              "      },\r",
              "      \"products\": {\r",
              "        \"type\": \"array\",\r",
              "        \"items\": {\r",
              "          \"type\": \"object\",\r",
              "          \"properties\": {\r",
              "            \"productId\": {\r",
              "              \"type\": \"number\"\r",
              "            },\r",
              "            \"quantity\": {\r",
              "              \"type\": \"number\"\r",
              "            }\r",
              "          },\r",
              "          \"required\": [\r",
              "            \"productId\",\r",
              "            \"quantity\"\r",
              "          ]\r",
              "        }\r",
              "      },\r",
              "      \"__v\": {\r",
              "        \"type\": \"number\"\r",
              "      }\r",
              "    },\r",
              "    \"required\": [\r",
              "      \"id\",\r",
              "      \"userId\",\r",
              "      \"date\",\r",
              "      \"products\",\r",
              "      \"__v\"\r",
              "    ]\r",
              "  }\r",
              "}\r",
              "\r",
              "pm.test(\"validate returned items are in sorted order\", function () {\r",
              "    let sorting_order = pm.request.url.query.get(\"sort\"); // 👈 BEST for Newman\r",
              "\r",
              "    console.log(\"Sorting order:\", sorting_order);\r",
              "\r",
              "    let ids = json_response.map(item => Number(item.id));\r",
              "    let sortedIds = [...ids].sort((a, b) => a - b);\r",
              "\r",
              "    if (sorting_order === 'asc') {\r",
              "        pm.expect(ids).to.eql(sortedIds);\r",
              "    } else if (sorting_order === 'desc') {\r",
              "        pm.expect(ids).to.eql([...sortedIds].reverse());\r",
              "    } else {\r",
              "        throw new Error(\"Invalid or missing 'sort' query param. Use 'asc' or 'desc'\");\r",
              "    }\r",
              "});\r",
              "pm.test(\"Expected JSON schema validation\", function(){\r",
              "    pm.response.to.have.jsonSchema(expected_schema);\r",
              "});\r",
              "\r",
              "pm.test(\"Response is an array and not empty\", function(){\r",
              "    pm.expect(json_response).to.be.a('array').and.not.be.empty;\r",
              "});\r",
              "\r",
              "pm.test(\"Length of the returned products(7)\", function(){\r",
              "    pm.expect(json_response.length).to.be.eql(7)\r",
              "});\r",
              "\r",
              "pm.test(\"successful response validation\", function(){\r",
              "    pm.response.to.have.status(200)\r",
              "});\r",
              "\r",
              "console.log(\"Final URL:\", pm.request.url.toString());"
            ],
